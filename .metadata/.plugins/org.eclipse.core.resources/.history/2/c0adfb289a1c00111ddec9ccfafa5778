<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:ms-aichain="http://www.mulesoft.org/schema/mule/ms-aichain"
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns:http="http://www.mulesoft.org/schema/mule/http"
      xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd
        http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd
        http://www.mulesoft.org/schema/mule/ms-aichain http://www.mulesoft.org/schema/mule/ms-aichain/current/mule-ms-aichain.xsd">

    <configuration-properties file="application.yaml"/>

    <http:listener-config name="HTTP_Listener_config" doc:name="HTTP Listener config">
        <http:listener-connection host="${http.host}" port="${http.port}"/>
    </http:listener-config>

    <ms-aichain:config
            name="MAC_Config"
            doc:name="MuleSoft AI Chain Config"
            llmType="OLLAMA"
            configType="Configuration Json"
            filePath='#[mule.home ++ "/apps/" ++ app.name ++ "/llm-config.json"]'
            modelName="llama3"
            temperature="0.2"
            llmTimeout="120"
            llmTimeoutUnit="SECONDS"
            maxTokens="800"/>

    <!-- GET para probar desde navegador -->
    <flow name="get-rag-ask-flow">
        <http:listener doc:name="GET /rag/ask"
                       config-ref="HTTP_Listener_config"
                       path="/rag/ask"
                       allowedMethods="GET"/>

        <ee:transform doc:name="Normalizar query param">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  question: attributes.queryParams.question default p("rag.defaultQuestion")
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>

        <set-variable variableName="originalQuestion"
                      value="#[payload.question]"
                      doc:name="Guardar pregunta original"/>

        <logger level="INFO"
                doc:name="Log pregunta GET"
                message='#[ "GET question = " ++ vars.originalQuestion ]'/>

        <ms-aichain:rag-load-document
                doc:name="RAG load document GET"
                config-ref="MAC_Config"
                contextPath='#[mule.home ++ "/apps/" ++ app.name ++ "/docs/txtpruebas.txt"]'
                target="ragResult" fileType='"text"'>
            <ms-aichain:data><![CDATA[#[payload.question]]]></ms-aichain:data>
        </ms-aichain:rag-load-document>

        <logger level="INFO"
                doc:name="Log salida RAG GET"
                message='#[ "RAG GET result = " ++ write(vars.ragResult, "application/json") ]'/>

        <ee:transform doc:name="Formatear respuesta GET">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  ok: true,
  question: vars.originalQuestion,
  answer: vars.ragResult.response default vars.ragResult,
  rawPayload: vars.ragResult
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>

        <error-handler>
            <on-error-continue logException="true" doc:name="Manejar error GET">
                <ee:transform doc:name="Error JSON GET">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  ok: false,
  errorType: error.errorType.identifier default "UNKNOWN",
  description: error.description default "Error ejecutando la PoC RAG GET",
  detailedDescription: error.detailedDescription default null
}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </on-error-continue>
        </error-handler>
    </flow>

    <!-- POST para pruebas tipo API -->
    <flow name="post-rag-ask-flow">
        <http:listener doc:name="POST /rag/ask"
                       config-ref="HTTP_Listener_config"
                       path="/rag/ask"
                       allowedMethods="POST"/>

        <ee:transform doc:name="Normalizar body">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
var bodyReq = payload default {}
---
{
  question: bodyReq.question default p("rag.defaultQuestion")
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>

        <set-variable variableName="originalQuestion"
                      value="#[payload.question]"
                      doc:name="Guardar pregunta original"/>

        <logger level="INFO"
                doc:name="Log pregunta POST"
                message='#[ "POST question = " ++ vars.originalQuestion ]'/>

        <ms-aichain:rag-load-document
                doc:name="RAG load document POST"
                config-ref="MAC_Config"
                contextPath='#[mule.home ++ "/apps/" ++ app.name ++ "/docs/txtpruebas.txt"]'
                target="ragResult" fileType='"text"'>
            <ms-aichain:data><![CDATA[#[payload.question]]]></ms-aichain:data>
        </ms-aichain:rag-load-document>

        <logger level="INFO"
                doc:name="Log salida RAG POST"
                message='#[ "RAG POST result = " ++ write(vars.ragResult, "application/json") ]'/>

        <ee:transform doc:name="Formatear respuesta POST">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  ok: true,
  question: vars.originalQuestion,
  answer: vars.ragResult.response default vars.ragResult,
  rawPayload: vars.ragResult
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>

        <error-handler>
            <on-error-continue logException="true" doc:name="Manejar error POST">
                <ee:transform doc:name="Error JSON POST">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  ok: false,
  errorType: error.errorType.identifier default "UNKNOWN",
  description: error.description default "Error ejecutando la PoC RAG POST",
  detailedDescription: error.detailedDescription default null
}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </on-error-continue>
        </error-handler>
    </flow>

</mule>